<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Roblox Stats Checker</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: Arial, sans-serif; background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460); min-height: 100vh; color: #fff; padding: 20px; }
.container { max-width: 700px; margin: 0 auto; }
h1 { text-align: center; color: #e94560; margin-bottom: 30px; font-size: 1.8em; }
.search-box { display: flex; gap: 10px; margin-bottom: 20px; }
input[type=text] { flex: 1; padding: 12px; border-radius: 10px; border: 2px solid #e94560; background: rgba(255,255,255,0.1); color: #fff; font-size: 1em; }
input::placeholder { color: rgba(255,255,255,0.5); }
button { padding: 12px 25px; background: #e94560; color: #fff; border: none; border-radius: 10px; font-size: 1em; cursor: pointer; }
.card { background: rgba(255,255,255,0.05); border: 1px solid rgba(233,69,96,0.3); border-radius: 15px; padding: 25px; margin-bottom: 15px; }
.profile { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
.avatar { width: 90px; height: 90px; border-radius: 50%; border: 3px solid #e94560; }
.profile-info h2 { color: #e94560; font-size: 1.4em; }
.profile-info p { color: rgba(255,255,255,0.6); margin-top: 4px; font-size: 0.9em; }
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 20px; }
.stat { background: rgba(233,69,96,0.1); border: 1px solid rgba(233,69,96,0.3); border-radius: 10px; padding: 12px; text-align: center; }
.stat .val { font-size: 1.3em; font-weight: bold; color: #e94560; }
.stat .lbl { font-size: 0.75em; color: rgba(255,255,255,0.6); margin-top: 4px; }
.games h3 { color: #e94560; margin-bottom: 12px; }
.game { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.05); border-radius: 10px; padding: 12px; margin-bottom: 8px; }
.game img { width: 70px; height: 45px; border-radius: 6px; object-fit: cover; }
.game h4 { font-size: 0.9em; }
.game p { font-size: 0.8em; color: rgba(255,255,255,0.5); margin-top: 3px; }
.msg { text-align: center; padding: 20px; color: rgba(255,255,255,0.6); }
.err { color: #e94560; }
</style>
</head>
<body>
<div class="container">
<h1>🎮 Roblox Stats Checker</h1>
<div class="search-box">
<input type="text" id="inp" placeholder="اكتب اسم المستخدم في Roblox..." onkeydown="if(event.key==='Enter')go()">
<button onclick="go()">🔍 بحث</button>
</div>
<div id="out"></div>
</div>
<script>
const SERVER='https://roblox-proxy-production-457a.up.railway.app';
function fmt(n){if(n==null)return'-';if(n>=1000000)return(n/1000000).toFixed(1)+'M';if(n>=1000)return(n/1000).toFixed(1)+'K';return n;}
async function go(){
const u=document.getElementById('inp').value.trim();
const o=document.getElementById('out');
if(!u)return;
o.innerHTML='<div class="msg">⏳ جاري البحث...</div>';
try{
const r=await fetch(`${SERVER}/api/user/${encodeURIComponent(u)}`);
if(!r.ok)throw new Error('مستخدم غير موجود');
const d=await r.json();
let games='';
if(d.games&&d.games.length){games='<div class="games"><h3>🎮 الألعاب</h3>'+d.games.map(g=>`<div class="game">${g.thumbUrl?`<img src="${g.thumbUrl}">`:''}<div><h4>${g.name}</h4><p>▶️ ${fmt(g.plays)} لعبة</p></div></div>`).join('')+'</div>';}
o.innerHTML=`<div class="card"><div class="profile">${d.avatarHead?`<img class="avatar" src="${d.avatarHead}">`:''}<div class="profile-info"><h2>${d.displayName}</h2><p>@${d.name}</p><p style="margin-top:8px;font-size:0.8em;color:rgba(255,255,255,0.4)">${d.description||'لا يوجد وصف'}</p></div></div><div class="stats-grid"><div class="stat"><div class="val">${fmt(d.friends)}</div><div class="lbl">👥 أصدقاء</div></div><div class="stat"><div class="val">${fmt(d.followers)}</div><div class="lbl">❤️ متابعون</div></div><div class="stat"><div class="val">${fmt(d.following)}</div><div class="lbl">➡️ يتابع</div></div><div class="stat"><div class="val">${fmt(d.badges)}</div><div class="lbl">🏅 شارات</div></div></div>${games}</div>`;
}catch(e){o.innerHTML=`<div class="msg err">❌ ${e.message}</div>`;}
}
</script>
</body>
</html>
